# G2B 나라장터 Open API 설정
# https://data.g2b.go.kr에서 인증키 발급
G2B_API_KEY=your_g2b_api_key_here

# 데이터베이스 설정
# SQLite 권장 (기본값: sqlite:///./bidding.db)
DATABASE_URL=sqlite:///./bidding.db

# 웹 서버 포트 (기본값: 8000)
API_PORT=8000

# 크론 스케줄 활성화 (true/false, 기본값: true)
CRON_ENABLED=true

# 구글 스프레드시트 설정 (선택사항)
# Google Cloud Platform에서 서비스 계정 키 생성 필요
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# 로깅 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# === 알림 설정 ===
# Daum SMTP 다이제스트 메일 (선택사항 — 미설정 시 발송 건너뜀)
# Daum 메일 설정 → IMAP/SMTP 사용 활성화 후 앱 비밀번호 사용 권장
SMTP_USER=your_account@daum.net
SMTP_PASSWORD=your_app_password
EMAIL_SENDER_NAME=덱스트 입찰공고 봇

# === Persona별 수신자 분리 ===
# DECISION_RECIPIENTS: 박이사 — 신규 공고 [참여]/[불참] + 48h 무결정 reminder + D-1 cc + 재공고 정보
DECISION_RECIPIENTS=ceo@dext.kr
# EXECUTOR_RECIPIENTS: 주니어(최나린·이효진) — [참여] 결정 후 즉시 알림 + D-3/D-1 + 재공고 [재제출완료]
EXECUTOR_RECIPIENTS=junior1@dext.kr,junior2@dext.kr
# MONITOR_EMAIL: 모니터링용 (사용자 본인). 모든 메일을 cc로 받음. 운영 안정화 후 비우면 메일 OFF.
MONITOR_EMAIL=monitor@dext.kr

# 레거시 호환 — 위 3개가 모두 비어있을 때 fallback. 신규 배포에선 비워둬도 됨.
EMAIL_RECIPIENTS=staff1@dext.kr,staff2@dext.kr

# Slack 48시간 에스컬레이션 (선택사항)
# Slack Incoming Webhook URL — 미설정 시 에스컬레이션 건너뜀
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# 메일 본문 및 Slack 메시지의 "대시보드 열기" 링크
DASHBOARD_URL=http://localhost:8000/

# === 결정 토큰 시크릿 (필수) ===
# 메일 안 "참여/패스/제출완료/재제출 완료" 링크 서명 키. 외부 노출 금지.
# 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
DECIDE_TOKEN_SECRET=please-generate-with-secrets-token_urlsafe-32
